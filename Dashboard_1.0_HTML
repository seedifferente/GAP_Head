<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard GAP Investor PRO</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        /* Estilos adicionales para asegurar que las gráficas se ajusten bien */
        .chart-container {
            position: relative;
            height: 400px;
            width: 100%;
        }
        @media (max-width: 768px) {
            .chart-container {
                height: 300px; /* Gráficas un poco más pequeñas en móviles */
            }
        }
    </style>
</head>
<body class="min-h-screen bg-slate-50 p-4 md:p-8 font-sans text-slate-900">

    <!-- HEADER & GLOBAL FILTERS -->
    <div class="max-w-7xl mx-auto mb-8 flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h1 class="text-3xl font-black tracking-tight text-slate-900 flex items-center gap-3">
                <div class="bg-indigo-600 p-2 rounded-lg">
                    <i data-lucide="trending-up" class="text-white w-6 h-6"></i>
                </div>
                GAP INVESTOR <span class="text-indigo-600 font-light">PRO</span>
            </h1>
            <p class="text-slate-500 mt-1" id="header-subtitle">Dashboard Realizado con Historial Completo • 2021-2026 • 1,323 Días Operativos</p>
        </div>
        
        <div class="flex flex-wrap gap-2 bg-white p-2 rounded-2xl shadow-sm border border-slate-100" id="filter-container">
            <!-- Botones generados dinámicamente -->
        </div>
    </div>

    <!-- KPI CARDS -->
    <div class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
        <!-- Beneficio -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-start justify-between transition-all duration-300 hover:shadow-md">
            <div>
                <p class="text-slate-500 text-sm font-medium mb-1" id="lbl-beneficio">Beneficio (Todos)</p>
                <h3 class="text-2xl font-bold text-slate-900" id="val-beneficio">$24,721.05</h3>
                <p class="text-xs mt-2 flex items-center text-emerald-600" id="sub-beneficio">+801.8% vs Sin Estrategia</p>
            </div>
            <div class="p-3 rounded-xl bg-emerald-500 transition-colors">
                <i data-lucide="arrow-up-right" class="text-white w-5 h-5"></i>
            </div>
        </div>

        <!-- Profit Factor -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-start justify-between transition-all duration-300 hover:shadow-md">
            <div>
                <p class="text-slate-500 text-sm font-medium mb-1">Profit Factor</p>
                <h3 class="text-2xl font-bold text-slate-900" id="val-profit-factor">1.61</h3>
                <p class="text-xs mt-2 flex items-center text-slate-400">Ventaja Estadística Real</p>
            </div>
            <div class="p-3 rounded-xl bg-indigo-500 transition-colors">
                <i data-lucide="activity" class="text-white w-5 h-5"></i>
            </div>
        </div>

        <!-- Win Rate -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-start justify-between transition-all duration-300 hover:shadow-md">
            <div>
                <p class="text-slate-500 text-sm font-medium mb-1">Win Rate</p>
                <h3 class="text-2xl font-bold text-slate-900" id="val-win-rate">21.39%</h3>
                <p class="text-xs mt-2 flex items-center text-slate-400">Consistencia Diaria</p>
            </div>
            <div class="p-3 rounded-xl bg-amber-500 transition-colors">
                <i data-lucide="target" class="text-white w-5 h-5"></i>
            </div>
        </div>

        <!-- Max Drawdown -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-start justify-between transition-all duration-300 hover:shadow-md">
            <div>
                <p class="text-slate-500 text-sm font-medium mb-1">Max Drawdown</p>
                <h3 class="text-2xl font-bold text-slate-900" id="val-drawdown">-8.4%</h3>
                <p class="text-xs mt-2 flex items-center text-slate-400">Riesgo Histórico (Solo A+B)</p>
            </div>
            <div class="p-3 rounded-xl bg-rose-500 transition-colors">
                <i data-lucide="alert-triangle" class="text-white w-5 h-5"></i>
            </div>
        </div>
    </div>

    <!-- BADGES / INSIGNIAS -->
    <div class="max-w-7xl mx-auto flex flex-wrap gap-4 mb-6 transition-all duration-300">
        <div class="bg-emerald-50 text-emerald-700 px-4 py-2 rounded-xl text-sm font-bold flex items-center gap-2 border border-emerald-200 shadow-sm w-full sm:w-auto justify-center">
            <i data-lucide="trending-up" class="w-4 h-4"></i> Mejor Operación: <span id="val-best-trade">+19.75%</span>
        </div>
        <div class="bg-emerald-50 text-emerald-700 px-4 py-2 rounded-xl text-sm font-bold flex items-center gap-2 border border-emerald-200 shadow-sm w-full sm:w-auto justify-center">
            <i data-lucide="arrow-up-right" class="w-4 h-4"></i> Ganancia Promedio: <span id="val-avg-win">+2.30%</span>
        </div>
        <div class="bg-rose-50 text-rose-700 px-4 py-2 rounded-xl text-sm font-bold flex items-center gap-2 border border-rose-200 shadow-sm w-full sm:w-auto justify-center">
            <i data-lucide="trending-down" class="w-4 h-4"></i> Peor Operación: <span id="val-worst-trade">-5.80%</span>
        </div>
        <div class="bg-rose-50 text-rose-700 px-4 py-2 rounded-xl text-sm font-bold flex items-center gap-2 border border-rose-200 shadow-sm w-full sm:w-auto justify-center">
            <i data-lucide="arrow-down-right" class="w-4 h-4"></i> Pérdida Promedio: <span id="val-avg-loss">-1.00%</span>
        </div>
    </div>

    <!-- CHARTS -->
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8 mb-10">
        
        <!-- Curva de Equidad -->
        <div class="lg:col-span-2 bg-white p-6 rounded-3xl shadow-sm border border-slate-100 flex flex-col">
            <div class="flex flex-col xl:flex-row xl:items-start justify-between mb-6 gap-4">
                <h3 class="font-bold text-lg text-slate-800" id="title-main-chart">Curva de Equidad Acumulada Real</h3>
                <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-medium xl:justify-end">
                    <div class="flex items-center gap-1.5"><div class="w-2 h-2 rounded-full bg-indigo-600"></div> A+B</div>
                    <div class="flex items-center gap-1.5"><div class="w-2 h-2 rounded-full bg-emerald-500"></div> Estrategia A</div>
                    <div class="flex items-center gap-1.5"><div class="w-2 h-2 rounded-full bg-amber-500"></div> Estrategia B</div>
                    <div class="flex items-center gap-1.5"><div class="w-2 h-2 rounded-full bg-slate-400"></div> Sin</div>
                </div>
            </div>
            <div class="chart-container">
                <canvas id="mainChart"></canvas>
            </div>
        </div>

        <!-- Gráfico P&L Dinámico -->
        <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-100 flex flex-col">
            <h3 class="font-bold text-lg text-slate-800 mb-2">Ganancias y Pérdidas (P&L)</h3>
            <p class="text-slate-400 text-xs mb-6" id="title-pnl-chart">Retorno Neto Mensual • Últimos 12 Meses</p>
            <div class="chart-container" style="height: 350px;">
                <canvas id="pnlChart"></canvas>
            </div>
        </div>

    </div>

    <script>
        // INICIALIZACIÓN DE ICONOS LUCIDE
        lucide.createIcons();

        // DATOS REALES
        const rawData = [
            {"fecha": "2021-01", "a_b": 147.14, "sin": 505.49, "estr_a": 149.43, "estr_b": -2.29}, 
