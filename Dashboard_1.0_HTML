            {"fecha": "2023-02", "a_b": 16042.24, "sin": -449.61, "estr_a": 8566.2, "estr_b": 7476.04}, 
            {"fecha": "2023-03", "a_b": 16765.08, "sin": -1783.99, "estr_a": 9557.82, "estr_b": 7207.26}, 
            {"fecha": "2023-04", "a_b": 17328.09, "sin": -681.84, "estr_a": 9612.25, "estr_b": 7715.83}, 
            {"fecha": "2023-05", "a_b": 17362.4, "sin": -1116.86, "estr_a": 9642.54, "estr_b": 7719.86}, 
            {"fecha": "2023-06", "a_b": 17732.88, "sin": -1700.41, "estr_a": 9877.67, "estr_b": 7855.21}, 
